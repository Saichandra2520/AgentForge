# ===========================================================
# {{ project_name }} - Environment Variables
# Copy this file to .env and fill in values
# ===========================================================

# LLM Provider: {{ llm_provider }}
{% if llm_provider == 'groq' %}GROQ_API_KEY=your_groq_api_key_here
# Get free key at: https://console.groq.com{% endif %}
{% if llm_provider == 'gemini' %}GEMINI_API_KEY=your_gemini_api_key_here
# Get free key at: https://aistudio.google.com{% endif %}
{% if llm_provider == 'azure' %}AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your_deployment_name{% endif %}
{% if llm_provider == 'ollama' %}OLLAMA_BASE_URL=http://localhost:11434
# Install Ollama: https://ollama.ai{% endif %}

{% if include_observability %}
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
{% endif %}
