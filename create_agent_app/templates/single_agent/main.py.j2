"""Local entrypoint for the generated single-agent app."""

from __future__ import annotations

from agents.agent import invoke_agent


def main() -> None:
    print("Single Agent CLI is ready. Type 'exit' to quit.")
    while True:
        query = input("\\nYou: ").strip()
        if query.lower() in {"exit", "quit"}:
            print("Goodbye")
            break
        if not query:
            continue
        answer = invoke_agent(query)
        print(f"Assistant: {answer}")


if __name__ == "__main__":
    main()