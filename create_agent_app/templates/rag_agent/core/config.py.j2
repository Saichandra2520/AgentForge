from pydantic_settings import BaseSettings
import yaml
from pathlib import Path


def _load_yaml() -> dict:
    yaml_path = Path(__file__).parent.parent / "config.yaml"
    if yaml_path.exists():
        with open(yaml_path) as f:
            return yaml.safe_load(f) or {}
    return {}


class Settings(BaseSettings):
    LLM_PROVIDER: str = "{{ llm_provider }}"
    GROQ_API_KEY: str = ""
    GEMINI_API_KEY: str = ""
    AZURE_OPENAI_API_KEY: str = ""
    AZURE_OPENAI_ENDPOINT: str = ""
    AZURE_OPENAI_DEPLOYMENT: str = ""
    OLLAMA_BASE_URL: str = "http://localhost:11434"
    {% if include_semantic_cache %}
    UPSTASH_VECTOR_URL: str = ""
    UPSTASH_VECTOR_TOKEN: str = ""
    {% endif %}
    {% if include_observability %}
    LANGFUSE_PUBLIC_KEY: str = ""
    LANGFUSE_SECRET_KEY: str = ""
    LANGFUSE_HOST: str = "https://cloud.langfuse.com"
    {% endif %}

    class Config:
        env_file = ".env"


_yaml = _load_yaml()
settings = Settings()

llm_config = _yaml.get("llm", {"provider": "{{ llm_provider }}", "temperature": 0.0})
retrieval_config = _yaml.get("retrieval", {"top_k": 5, "hybrid_weight": 0.7, "reranker_top_k": 3})
crag_config = _yaml.get("crag", {"correct_threshold": 0.90, "incorrect_threshold": 0.50, "max_retries": 2})
cache_config = _yaml.get("semantic_cache", {"enabled": False, "similarity_threshold": 0.90, "ttl_seconds": 3600})
guards_config = _yaml.get("guards", {
    "input_guard": True,
    "output_guard": True,
    "domain_filter": True,
    "domain_description": "{{ agent_description }}",
})
